#### DATABASE ENV ####
DB_DRIVER=sqlite
DB_NAME=GO_FRAMEWORK

#### SERVER ENV ####
APP_NAME=GO_FRAMEWORK
APP_PORT=8080
APP_HOST=localhost
APP_ENV=development
APP_URL=http://localhost:8080
APP_TIMEZONE=Asia/Jakarta

#### STORAGE ####
STORAGE_DISK=s3 # local atau s3

# Konfigurasi Lokal
STORAGE_ROOT=./public/storage
STORAGE_BASE_URL=http://localhost:8080/storage

# Konfigurasi S3 / Supabase / Minio
# S3_KEY=your-project-ref-id 
# S3_SECRET=your-service-role-key 
# S3_REGION=ap-southeast-1
# S3_BUCKET=my-bucket-name
# S3_ENDPOINT=https://your-ref.supabase.co/storage/v1/s3
# S3_USE_PATH_STYLE=true

#### CACHE & QUEUE ####
CACHE_DRIVER=memory
QUEUE_DRIVER=sync
QUEUE_BUFFER_SIZE=100
# REDIS_HOST =
# REDIS_PORT =
# REDIS_PASSWORD =
# REDIS_DB =

#### CORS ####
CORS_ALLOW_ORIGINS=*
CORS_ALLOW_HEADERS=Origin,Content-Type,Accept,Authorization


MAIL_MAILER=log # Use "smtp" for production
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=your_username
MAIL_PASSWORD=your_password
MAIL_FROM_ADDRESS=hello@gons.dev
